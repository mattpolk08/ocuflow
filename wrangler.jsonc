{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "oculoflow",
  "compatibility_date": "2026-03-07",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "OCULOFLOW_KV",
      "id": "3de6133cdd914fa7b9b6eea4142322e0"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "oculoflow-production",
      "database_id": "2f41b1ae-97d6-428e-88a4-35be330cc81c"
    }
  ],
  // R2 binding is configured in the Cloudflare Pages dashboard (Settings → Functions → R2 bucket bindings)
  // binding name: OCULOFLOW_R2  →  bucket: oculoflow-documents
  // Do NOT declare r2_buckets here — wrangler pages deploy will error if the bucket doesn't exist yet.
  "vars": {
    "DEMO_MODE": "true",
    "PRACTICE_NAME": "Advanced Eye Care of Miami"
  }
}
